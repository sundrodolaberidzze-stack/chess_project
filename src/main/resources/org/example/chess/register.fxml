<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="18.0" prefWidth="420.0" prefHeight="360.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.chess.controllers.RegisterController"
      style="-fx-background-color: #302E2B; -fx-padding: 40;">

    <Label text="Register Account"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>

    <GridPane alignment="CENTER" hgap="12" vgap="12">
        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0"
               style="-fx-text-fill: #BABABA;"/>
        <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                   style="-fx-background-color: #3D3B38; -fx-text-fill: white; -fx-border-color: #555; -fx-border-radius: 4; -fx-background-radius: 4;"
                   promptText="Choose username"/>
        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="1"
               style="-fx-text-fill: #BABABA;"/>
        <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                       style="-fx-background-color: #3D3B38; -fx-text-fill: white; -fx-border-color: #555; -fx-border-radius: 4; -fx-background-radius: 4;"
                       promptText="Choose password"/>
    </GridPane>

    <HBox alignment="CENTER" spacing="12.0">
        <Button text="Register" onAction="#handleRegister"
                style="-fx-background-color: #81B64C; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 24 8 24; -fx-border-radius: 4; -fx-background-radius: 4;"/>
        <Button text="Back to Login" onAction="#handleBackToLogin"
                style="-fx-background-color: #555; -fx-text-fill: white; -fx-padding: 8 18 8 18; -fx-border-radius: 4; -fx-background-radius: 4;"/>
    </HBox>

    <Label fx:id="statusLabel" style="-fx-font-size: 12px;"/>
</VBox>
