<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="22.0" prefWidth="520.0" prefHeight="480.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.chess.controllers.SettingsController"
      style="-fx-background-color: #302E2B; -fx-padding: 40;">

    <Label text="Settings"
           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>

    <VBox alignment="CENTER_LEFT" spacing="18.0" maxWidth="330.0">
        <CheckBox fx:id="premovesCheckBox" text="Enable Premoves" onAction="#handlePremovesToggle"
                  style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px;"/>
        <CheckBox fx:id="fullscreenCheckBox" text="Fullscreen On All Windows" onAction="#handleFullscreenToggle"
                  style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px;"/>
        <HBox alignment="CENTER_LEFT" spacing="14.0">
            <Label text="Board Color:" style="-fx-text-fill: #BABABA; -fx-font-size: 14px;"/>
            <ComboBox fx:id="boardColorComboBox" onAction="#handleBoardColorChange" prefWidth="150.0"/>
        </HBox>
    </VBox>

    <Button text="Back to Main Menu" onAction="#handleBack"
            style="-fx-background-color: #555; -fx-text-fill: white; -fx-padding: 10 24 10 24; -fx-border-radius: 5; -fx-background-radius: 5;"/>
</VBox>
