<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="420.0" prefHeight="380.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.chess.controllers.LoginController"
            style="-fx-background-color: #302E2B;">
    <center>
        <VBox alignment="CENTER" spacing="18.0" style="-fx-padding: 40;">
            <Label text="♟ Chess Login"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
            <GridPane alignment="CENTER" hgap="12" vgap="12">
                <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                       style="-fx-text-fill: #BABABA; -fx-font-size: 13px;"/>
                <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                           style="-fx-background-color: #3D3B38; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-border-color: #555; -fx-border-radius: 4; -fx-background-radius: 4;"
                           promptText="Enter username"/>
                <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                       style="-fx-text-fill: #BABABA; -fx-font-size: 13px;"/>
                <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                               style="-fx-background-color: #3D3B38; -fx-text-fill: white; -fx-border-color: #555; -fx-border-radius: 4; -fx-background-radius: 4;"
                               promptText="Enter password"/>
            </GridPane>
            <HBox alignment="CENTER" spacing="12.0">
                <Button text="Login" onAction="#handleLogin"
                        style="-fx-background-color: #81B64C; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 24 8 24; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                <Button text="Register" onAction="#handleGoToRegister"
                        style="-fx-background-color: #555; -fx-text-fill: white; -fx-padding: 8 18 8 18; -fx-border-radius: 4; -fx-background-radius: 4;"/>
            </HBox>
            <Label fx:id="errorLabel" textFill="red" style="-fx-font-size: 12px;"/>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 16 12 0;">
            <Button text="Database Setup" onAction="#handleGoToDBSetup"
                    style="-fx-background-color: transparent; -fx-text-fill: #888; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>
</BorderPane>
